{
    "name": "sv-asm",
    "version": "0.0.1",
    "engines": {
        "vscode": ">=0.9.0-pre.1"
    },
    "publisher": "micuri",
    "contributes": {
        "languages": [{
            "id": "sv-asm",
            "extensions": [".sv.asm"]
        }],
        "grammars": [{
            "language": "sv-asm",
            "scopeName": "source.sv-asm",
            "path": "./syntaxes/sv-asm.tmLanguage"
        }],
        "configurationDefaults": {
            "[sv-asm]": {
                "editor.renderWhitespace": "all",
                "editor.stickyTabStops": true,
                "editor.detectIndentation": false,
                "editor.insertSpaces": true
            },
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": "meta.preprocessor.sv-asm",
                        "settings": {
                            "foreground": "#1d881f",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": "support.function.sv-asm",
                        "settings": {
                            "foreground": "#dd4d63",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": "variable.other.register.usable.by-number.sv-asm",
                        "settings": {
                            "foreground": "#dce06a"
                        }
                    },
                    {
                        "scope": "variable.other.register.usable.by-name.sv-asm",
                        "settings": {
                            "foreground": "#dce06a"
                        }
                    }
                ]
            }
		},
        "keybindings": [
            {
                "key": "ctrl+; t",
                "command": "editor.action.indentationToTabs"
            },
            {
                "key": "ctrl+; r",
                "command": "workbench.action.reloadWindow"
            }
        ]
    }
}